<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Taxpayer Q&amp;A POC</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="bg-light">
  <header class="bg-white border-bottom mb-4">
    <div class="container py-3 d-flex align-items-baseline gap-2">
      <span class="brand-dot"></span>
      <h1 class="h5 mb-0">Taxpayer Q&amp;A</h1>
      <span class="text-muted small ms-2">Ollama &middot; gemma3:12b</span>
    </div>
  </header>

  <form method="POST" action="/ask">
    <div class="container pb-5">
      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card mb-4">
            <div class="card-body">
              <label for="taxpayerId" class="form-label fw-semibold">Taxpayer</label>
              <select id="taxpayerId" name="taxpayerId" class="form-select">
                <% taxpayers.forEach(function (t) { %>
                  <option value="<%= t.id %>" <%= t.id === selectedTaxpayerId ? "selected" : "" %>><%= t.label %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <div class="card mb-4">
            <div class="card-body">
              <label for="freeformQuestion" class="form-label fw-semibold">Free-form question(s)</label>
              <textarea
                id="freeformQuestion"
                name="freeformQuestion"
                rows="6"
                class="form-control"
                placeholder="Type one question per line...&#10;e.g. Did the taxpayer claim any dependents?"
              ><%= freeformQuestion %></textarea>
              <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-primary">Ask AI</button>
              </div>
            </div>
          </div>

          <% if (result) { %>
            <div class="card">
              <div class="card-body">
                <% if (result.error) { %>
                  <div class="alert alert-danger mb-0"><%= result.error %></div>
                <% } else { %>
                  <h2 class="h6 mb-3">Answers</h2>
                  <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                      <thead>
                        <tr><th>Question</th><th>Answer</th></tr>
                      </thead>
                      <tbody>
                        <% result.rows.forEach(function (row) { %>
                          <tr>
                            <td><%= row.questionText %></td>
                            <td><%- row.html %></td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>

        <div class="col-lg-5">
          <div class="card sticky-top" style="top: 1.5rem;">
            <div class="card-body">
              <label class="form-label fw-semibold">Questions</label>
              <div class="accordion" id="questionAccordion">
                <% Object.keys(groupedQuestions).sort().forEach(function (category, idx) { %>
                  <% const allChecked = groupedQuestions[category].every(function (q) { return checkedQuestionIds.includes(q.id); }); %>
                  <div class="accordion-item">
                    <h2 class="accordion-header d-flex align-items-center">
                      <input
                        type="checkbox"
                        class="form-check-input category-checkbox flex-shrink-0 ms-3"
                        data-category="<%= category %>"
                        <%= allChecked ? "checked" : "" %>
                      />
                      <button
                        class="accordion-button <%= idx === 0 ? "" : "collapsed" %> py-2"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#cat-<%= idx %>"
                      >
                        <%= category %>
                      </button>
                    </h2>
                    <div id="cat-<%= idx %>" class="accordion-collapse collapse <%= idx === 0 ? "show" : "" %>" data-bs-parent="#questionAccordion">
                      <div class="accordion-body py-2">
                        <% groupedQuestions[category].forEach(function (q) { %>
                          <div class="form-check d-flex align-items-start gap-2 mb-2">
                            <input
                              class="form-check-input question-checkbox mt-1"
                              type="checkbox"
                              name="questionIds"
                              value="<%= q.id %>"
                              data-category="<%= category %>"
                              id="q-<%= q.id %>"
                              <%= checkedQuestionIds.includes(q.id) ? "checked" : "" %>
                            />
                            <label class="form-check-label flex-grow-1" for="q-<%= q.id %>">
                              <%= q.text %>
                              <span class="badge text-bg-light border ms-1"><%= q.answerDataType %></span>
                            </label>
                          </div>
                        <% }); %>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>

          <% if (result && result.stats) { %>
            <div class="ai-stats mt-4">
              <div class="ai-stats-header">
                <span class="ai-stats-pulse"></span>
                AI response stats
              </div>
              <div class="ai-stats-grid">
                <div class="ai-stat">
                  <span class="ai-stat-value"><%= (result.stats.elapsedMs / 1000).toFixed(1) %>s</span>
                  <span class="ai-stat-label">Response time</span>
                </div>
                <div class="ai-stat">
                  <span class="ai-stat-value"><%= result.stats.tokensPerSecond.toFixed(0) %></span>
                  <span class="ai-stat-label">Tokens / sec</span>
                </div>
                <div class="ai-stat">
                  <span class="ai-stat-value"><%= result.stats.responseTokens %></span>
                  <span class="ai-stat-label">Output tokens</span>
                </div>
                <div class="ai-stat">
                  <span class="ai-stat-value"><%= result.questionCount %></span>
                  <span class="ai-stat-label">Questions answered</span>
                </div>
              </div>
              <div class="ai-stats-foot">
                <%= result.stats.model %>
                &middot; <%= result.stats.promptTokens %> prompt tokens
                <% if (result.stats.loadDurationMs > 1) { %>
                  &middot; <%= (result.stats.loadDurationMs / 1000).toFixed(1) %>s model load
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </form>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      document.querySelectorAll(".category-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", function () {
          const category = this.dataset.category;
          const isChecked = this.checked;
          document.querySelectorAll(`.question-checkbox[data-category="${category}"]`).forEach((q) => {
            q.checked = isChecked;
          });
        });
      });

      document.querySelectorAll(".question-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", function () {
          const category = this.dataset.category;
          updateCategoryCheckboxState(category);
        });
      });

      function updateCategoryCheckboxState(category) {
        const questionCheckboxes = document.querySelectorAll(`.question-checkbox[data-category="${category}"]`);
        const categoryCheckbox = document.querySelector(`.category-checkbox[data-category="${category}"]`);
        const allChecked = Array.from(questionCheckboxes).every((q) => q.checked);
        const someChecked = Array.from(questionCheckboxes).some((q) => q.checked);
        categoryCheckbox.checked = allChecked;
        categoryCheckbox.indeterminate = someChecked && !allChecked;
      }
    });
  </script>
</body>
</html>
