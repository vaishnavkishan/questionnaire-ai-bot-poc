<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Taxpayer Q&amp;A POC</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="app-header">
    <div class="brand">
      <span class="brand-mark"></span>
      <h1>Taxpayer Q&amp;A</h1>
    </div>
    <p class="subtitle">Ollama &middot; gemma3:12b</p>
  </header>

  <form method="POST" action="/ask" class="layout">
    <section class="col col-left">
      <div class="card">
        <div class="field">
          <label for="taxpayerId">Taxpayer</label>
          <select id="taxpayerId" name="taxpayerId">
            <% taxpayers.forEach(function (t) { %>
              <option value="<%= t.id %>" <%= t.id === selectedTaxpayerId ? "selected" : "" %>><%= t.label %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="card chat-card">
        <div class="field">
          <label for="freeformQuestion">Free-form question(s)</label>
          <textarea
            id="freeformQuestion"
            name="freeformQuestion"
            rows="6"
            placeholder="Type one question per line...&#10;e.g. Did the taxpayer claim any dependents?"
          ><%= freeformQuestion %></textarea>
        </div>
        <div class="actions">
          <button type="submit">Ask AI</button>
        </div>
      </div>

      <% if (result) { %>
        <div class="card result-card">
          <% if (result.error) { %>
            <p class="error"><%= result.error %></p>
          <% } else { %>
            <h2>Answers</h2>
            <table>
              <thead>
                <tr><th>Question</th><th>Answer</th></tr>
              </thead>
              <tbody>
                <% result.rows.forEach(function (row) { %>
                  <tr>
                    <td><%= row.questionText %></td>
                    <td><%- row.html %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      <% } %>
    </section>

    <aside class="col col-right">
      <div class="card questions-card">
        <label>Questions</label>
        <div class="checkbox-list">
          <% questionnaire.forEach(function (q) { %>
            <label class="checkbox-item">
              <input
                type="checkbox"
                name="questionIds"
                value="<%= q.id %>"
                <%= checkedQuestionIds.includes(q.id) ? "checked" : "" %>
              />
              <span class="checkbox-text"><%= q.text %></span>
              <span class="type-tag"><%= q.answerDataType %></span>
            </label>
          <% }); %>
        </div>
      </div>
    </aside>
  </form>
</body>
</html>
